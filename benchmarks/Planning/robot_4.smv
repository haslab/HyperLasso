MODULE main
VAR
    x : 0..3;
    y : 0..3;
    d : 0..3;
ASSIGN
    init(x) := {0,1,2,3};
    next(x) := case
        d = 0 & x < 3 : x + 1;
        d = 2 & x > 0 : x - 1;
        TRUE : x;
    esac;
    init(y) := {0,1,2,3};
    next(y) := case
        d = 1 & y < 3 : y + 1;
        d = 3 & y > 0 : y - 1;
        TRUE : y;
    esac;
    init(d) := {0, 1, 2, 3};
    next(d) := {0, 1, 2, 3};
